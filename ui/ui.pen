                  "fontWeight": "700"
                },
                {
                  "type": "frame",
                  "id": "hlCZh",
                  "name": "annotatedPara",
                  "width": "fill_container",
                  "fill": "#00000000",
                  "children": [
                    {
                      "type": "frame",
                      "id": "L4RUN",
                      "name": "paraContent",
                      "width": "fill_container",
                      "fill": "#00000000",
                      "layout": "vertical",
                      "children": [
                        {
                          "type": "text",
                          "id": "J7VlE",
                          "name": "para2",
                          "fill": "#A1A1AA",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "在物理学中，第一性原理指的是不能从其他假设推导出来的基本命题。将这种思维应用到商业领域，意味着我们需要抛弃行业惯例和类比推理，从最根本的事实出发思考问题。",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
