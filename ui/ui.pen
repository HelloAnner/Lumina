                            {
                              "type": "text",
                              "id": "ul9gk",
                              "name": "hlLabelText",
                              "fill": "#8B5CF6",
                              "content": "关键洞察",
                              "fontFamily": "Inter",
                              "fontSize": 11,
                              "fontWeight": "600",
                              "letterSpacing": 0.5
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "iLWXg",
                          "name": "hlText",
                          "fill": "#D4D4D8",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "\"真正的创新不是在已有框架内做优化，而是质疑框架本身。第一性原理思维让我们能够从零开始构建新的可能性。\"",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
